        {"id": "CE010", "name": "os.spawnl", "pattern": "os\\.spawn[lvep]+\\s*\\(", "severity": "high", "description": "生成新进程"},
        {"id": "CE011", "name": "os.execv", "pattern": "os\\.exec[vple]+\\s*\\(", "severity": "high", "description": "执行新程序"},
